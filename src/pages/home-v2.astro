---
import { Image } from "astro:assets";
import {
  Activity,
  Bone,
  BriefcaseBusiness,
  CalendarDays,
  CircleHelp,
  Dumbbell,
  Footprints,
  Handshake,
  HeartHandshake,
  Hospital,
  MapPin,
  Phone,
  Play,
  RefreshCw,
  Scale,
  Search,
  ShieldCheck,
  Sprout,
  Star,
  Stethoscope,
  Trophy,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import logoWhite from "../assets/brand/logo-white.svg";
import franklintonClinic from "../assets/clinics/franklinton.jpg";
import hattiesburgClinic from "../assets/clinics/hattiesburg.jpg";
import ponchatoulaClinic from "../assets/clinics/ponchatoula.jpg";
import manualTherapyImage from "../assets/editorial/manual-therapy.jpeg";
import rehabSessionImage from "../assets/editorial/rehab-session.jpeg";
import treatmentRoomImage from "../assets/editorial/treatment-room.jpeg";

const heroVideo = "/assets/video/physical-therapy-action.mp4";

const trustItems = [
  { icon: MapPin, title: "6 Convenient Locations", detail: "Louisiana & Mississippi" },
  { icon: ShieldCheck, title: "Insurance Accepted", detail: "Most major plans covered" },
  { icon: Stethoscope, title: "Doctor Referrals Welcome", detail: "Trusted by physicians regionwide" },
  { icon: Star, title: "Thousands Treated", detail: "5-star rated on Google" },
];

const differentiators = [
  {
    icon: Search,
    title: "Whole-Body Evaluation",
    copy: "We find what others miss. Your first visit includes a comprehensive assessment of your entire body, not just where it hurts.",
  },
  {
    icon: Handshake,
    title: "Your Therapist. Every Visit.",
    copy: "The same licensed therapist guides your recovery, building the relationship that makes treatment work.",
  },
  {
    icon: HeartHandshake,
    title: "When You're Here, You're Family",
    copy: "From your first call to your last session, you're known, welcomed, and genuinely cared for.",
  },
  {
    icon: Trophy,
    title: "Trusted by Physicians Regionwide",
    copy: "Doctors across Louisiana and Mississippi refer patients because they trust our team to care with purpose.",
  },
];

const conditions = [
  { icon: Bone, name: "Back & Hip Pain", copy: "Lower back pain, sciatica, disc problems, and hip mobility issues." },
  { icon: Activity, name: "Knee Injuries", copy: "ACL tears, meniscus issues, knee replacement recovery, and runner's knee." },
  { icon: Dumbbell, name: "Shoulder & Arm", copy: "Rotator cuff injuries, elbow pain, wrist conditions, and frozen shoulder." },
  { icon: Footprints, name: "Foot & Ankle", copy: "Plantar fasciitis, Achilles problems, ankle sprains, and instability." },
  { icon: Stethoscope, name: "Neck & Nerve Pain", copy: "Pinched nerves, headaches, whiplash recovery, and cervical pain." },
  { icon: Scale, name: "Balance Disorders", copy: "Fall prevention, vestibular rehab, coordination, and stability." },
  { icon: Hospital, name: "Post-Surgical Recovery", copy: "Hip, knee, spine, and rotator cuff recovery with clear progression." },
  { icon: RefreshCw, name: "Chronic Pain", copy: "Persistent pain, arthritis, fibromyalgia, and long-term injury management." },
];

const steps = [
  ["1", "Request Your Appointment", "Call us or submit a request online. Our team will help you schedule at the clinic that fits your week."],
  ["2", "Your Whole-Body Evaluation", "Your therapist takes the time to understand what hurts, why it may be happening, and what life needs to look like again."],
  ["3", "Your Personalized Plan", "Every session is hands-on, purposeful, and built around your body, your goals, and your progress."],
  ["4", "Get Back to Living", "We measure progress, celebrate milestones, and help you return to the routines and people you love."],
];

const reviews = [
  ["M", "Margaret T.", "Covington, LA · Post-Surgical Recovery", "I came in after my knee replacement not knowing what to expect. My therapist was with me every step of the way. Eight weeks later I was back in my garden."],
  ["D", "David K.", "Hattiesburg, MS · Shoulder Injury Recovery", "I'd tried PT before and it did nothing. CarePT was completely different. They listened, found the real problem, and got me back to the gym."],
  ["S", "Sandra W.", "Bogalusa, LA · Chronic Back Pain", "My back pain had been chronic for three years. Six weeks in, I slept through the night for the first time in years."],
];

const avatars = [
  { icon: Bone, label: "Post-Surgical Recovery", name: "The Comeback Patient", copy: "You've had surgery and need a team you can trust to guide every step, not just hand you exercises.", tags: ["Joint Replacement", "Spinal Surgery", "Rotator Cuff"] },
  { icon: Activity, label: "Sports & Athletic Injury", name: "The Sidelined Achiever", copy: "You're active, competitive, and ready to work for a fast, evidence-based recovery.", tags: ["Sports Injuries", "Training", "Performance"] },
  { icon: Sprout, label: "Active Aging & Independence", name: "The Independent Senior", copy: "Whether it's balance, joint pain, or keeping up with family, your independence matters.", tags: ["Balance", "Arthritis", "Active Aging"] },
  { icon: BriefcaseBusiness, label: "Work & Life Balance", name: "The Busy Parent / Professional", copy: "Six locations, practical scheduling, and efficient sessions designed for real life.", tags: ["Work Injuries", "Back & Neck Pain", "Flexible Hours"] },
  { icon: HeartHandshake, label: "Chronic & Persistent Pain", name: "The Chronic Pain Warrior", copy: "If you've tried things before, our whole-body evaluation is designed to find what others missed.", tags: ["Chronic Back Pain", "Fibromyalgia", "Persistent Pain"] },
];

const locations = [
  { city: "Bogalusa", state: "Louisiana", phone: "(985) 735-1426", image: manualTherapyImage, alt: "CarePT hands-on therapy session" },
  { city: "Covington", state: "Louisiana", phone: "(985) 249-6111", image: treatmentRoomImage, alt: "CarePT treatment room" },
  { city: "Franklinton", state: "Louisiana", phone: "(985) 795-1746", image: franklintonClinic, alt: "CarePT Franklinton clinic" },
  { city: "Ponchatoula", state: "Louisiana", phone: "(985) 386-2222", image: ponchatoulaClinic, alt: "CarePT Ponchatoula clinic" },
  { city: "Hattiesburg", state: "Mississippi", phone: "(601) 296-0199", image: hattiesburgClinic, alt: "CarePT Hattiesburg clinic" },
  { city: "Sumrall", state: "Mississippi", phone: "(601) 758-3333", image: rehabSessionImage, alt: "CarePT rehabilitation session" },
];
---

<BaseLayout
  title="CarePT Home V2"
  description="A second CarePT homepage concept with a refined authority layout for comparison."
>
  <SiteHeader />

  <main class="bg-white pt-[78px] font-sans text-slate-900">
    <section class="grid min-h-[88vh] overflow-hidden bg-gradient-to-b from-skybrand-200 via-skybrand-50 to-white lg:grid-cols-2">
      <div class="relative z-10 flex flex-col justify-center px-6 py-20 sm:px-10 lg:px-20">
        <div class="mb-8 inline-flex w-fit items-center gap-3 rounded-full border border-slate-700/30 bg-white/70 px-4 py-2">
          <ShieldCheck class="h-4 w-4" />
          <span class="text-xs font-bold uppercase tracking-[0.1em] text-slate-700">Doctor-trusted · Insurance accepted</span>
        </div>

        <h1 class="max-w-2xl font-display text-[clamp(42px,4.5vw,64px)] font-black leading-[1.1] tracking-[-0.02em] text-slate-950">
          Get Your <em class="animate-animated-text bg-[linear-gradient(-45deg,#80be41,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent not-italic">Life</em> Back.<br />
        </h1>
        <p class="mt-7 max-w-xl text-lg font-light leading-8 text-slate-700">
          Individualized, hands-on care at 6 convenient locations across Louisiana and Mississippi. When you're here,
          you're family.
        </p>

        <div class="mt-11 flex flex-wrap items-center gap-4">
          <a href="#appointment" class="inline-flex min-h-14 items-center justify-center rounded-[10px] bg-goldbrand-500 px-8 text-[15px] font-bold text-slate-950 transition hover:-translate-y-0.5 hover:bg-goldbrand-400 hover:shadow-elevated">
            <CalendarDays class="h-4 w-4" />
            Request an Appointment
          </a>
          <a href="#stories" class="inline-flex min-h-14 items-center justify-center rounded-[10px] border border-skybrand-800/25 px-7 text-[15px] font-semibold text-skybrand-900 transition hover:border-skybrand-800/50 hover:bg-white/60">
            <Play class="h-4 w-4" />
            Watch Our Story
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-6 text-sm text-slate-500">
          <div>
            <div class="tracking-[0.16em] text-goldbrand-300">★★★★★</div>
            <div><strong class="text-slate-900">Hundreds of 5-star reviews</strong> on Google</div>
          </div>
          <div class="hidden h-7 w-px bg-skybrand-900/15 sm:block"></div>
          <div><strong class="text-slate-900">6 locations</strong><br />LA & MS</div>
          <div class="hidden h-7 w-px bg-skybrand-900/15 sm:block"></div>
          <div><strong class="text-slate-900">Thousands</strong> treated<br />since 2005</div>
        </div>
      </div>

      <div class="relative min-h-[520px] overflow-hidden bg-gradient-to-br from-skybrand-500 via-skybrand-700 to-skybrand-900">
        <video autoplay muted loop playsinline preload="metadata" poster={rehabSessionImage.src} aria-label="Physical therapy session in progress" class="absolute inset-0 h-full w-full object-cover">
          <source src={heroVideo} type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-skybrand-900/15 to-transparent"></div>
      </div>
    </section>

    <section class="flex flex-wrap items-center justify-center gap-8 border-y border-skybrand-900/10 bg-[#F4F1EB] px-6 py-6 lg:gap-14">
      {trustItems.map((item, index) => (
        <>
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-skybrand-800 text-white">
              {(() => {
                const Icon = item.icon;
                return <Icon class="h-[18px] w-[18px]" />;
              })()}
            </div>
            <div class="leading-tight">
              <strong class="block text-[15px] text-slate-900">{item.title}</strong>
              <span class="text-xs text-slate-400">{item.detail}</span>
            </div>
          </div>
          {index < trustItems.length - 1 && <div class="hidden h-9 w-px bg-skybrand-900/15 lg:block"></div>}
        </>
      ))}
    </section>

    <section id="about" class="mx-auto grid max-w-[1280px] items-center gap-14 px-6 py-24 lg:grid-cols-2 lg:px-10 xl:px-16">
      <div>
        <p class="mb-4 flex items-center gap-3 text-xs font-bold uppercase tracking-[0.12em] text-skybrand-600 before:block before:h-0.5 before:w-7 before:bg-skybrand-600">Our Promise to You</p>
        <h2 class="font-display text-[clamp(32px,3vw,46px)] font-bold leading-[1.15] tracking-[-0.02em] text-slate-900">
          More Than a Clinic.<br />We're <em class="text-skybrand-800">Your</em> Team.
        </h2>
        <p class="mt-6 text-base leading-8 text-slate-600">
          At Care Physical Therapy, pain is never just physical. It touches how you sleep, how you move, and how you show
          up for the people who matter most.
        </p>
        <p class="mt-5 text-base leading-8 text-slate-600">
          That's why we do not just treat the injury. We evaluate your whole body, understand your whole life, and build a
          recovery plan around your specific goals.
        </p>
        <div class="mt-8 inline-flex items-center gap-3 rounded-xl bg-gradient-to-br from-skybrand-800 to-skybrand-500 px-5 py-3 font-display text-sm italic text-white">
          ✦ "To inspire and empower through healing."
        </div>
      </div>
      <div class="space-y-5 rounded-3xl border border-skybrand-900/10 bg-gradient-to-br from-[#F4F1EB] to-skybrand-50 p-8">
        {differentiators.map((item) => (
          <div class="flex gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-skybrand-800 text-white">
              {(() => {
                const Icon = item.icon;
                return <Icon class="h-5 w-5" />;
              })()}
            </div>
            <div>
              <h3 class="text-sm font-bold text-slate-900">{item.title}</h3>
              <p class="mt-1 text-[13px] leading-6 text-slate-600">{item.copy}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="conditions" class="bg-[#FAF8F4] px-6 py-24 lg:px-10 xl:px-16">
      <div class="mx-auto max-w-[1280px]">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-skybrand-600">What We Treat</p>
          <h2 class="font-display text-[clamp(32px,3vw,46px)] font-bold leading-[1.15] tracking-[-0.02em]">
            Whatever Is Keeping You <em class="text-skybrand-800">Sidelined</em>, We've Seen It. We Can Help.
          </h2>
          <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-slate-600">Our licensed therapists have successfully treated thousands of patients across these conditions and many more.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {conditions.map((condition) => (
            <article class="group rounded-2xl border border-skybrand-900/10 bg-white p-6 text-center transition hover:-translate-y-1 hover:border-skybrand-800/20 hover:shadow-card">
              <div class="mx-auto mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-skybrand-50 text-skybrand-700 ring-1 ring-skybrand-100">
                {(() => {
                  const Icon = condition.icon;
                  return <Icon class="h-5 w-5" />;
                })()}
              </div>
              <h3 class="text-sm font-bold text-slate-900">{condition.name}</h3>
              <p class="mt-2 text-xs leading-5 text-slate-400">{condition.copy}</p>
              <div class="mx-auto mt-5 h-0.5 w-0 bg-gradient-to-r from-skybrand-800 to-skybrand-500 transition-all group-hover:w-full"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1280px] px-6 py-24 lg:px-10 xl:px-16">
      <div class="mx-auto mb-16 max-w-3xl text-center">
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-skybrand-600">Your Recovery Journey</p>
        <h2 class="font-display text-[clamp(32px,3vw,46px)] font-bold leading-[1.15] tracking-[-0.02em]">Four Simple Steps to <em class="text-skybrand-800">Feeling Like Yourself Again</em></h2>
      </div>
      <div class="grid gap-8 lg:grid-cols-4">
        {steps.map(([number, title, copy], index) => (
          <article class="text-center">
            <div class:list={["mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full border-4 border-white font-display text-2xl font-black text-white shadow-[0_0_0_2px_currentColor]", index % 2 ? "bg-skybrand-500 text-skybrand-500" : "bg-skybrand-800 text-skybrand-800"]}>
              <span class="text-white">{number}</span>
            </div>
            <h3 class="text-base font-bold text-slate-900">{title}</h3>
            <p class="mt-3 text-[13px] leading-6 text-slate-600">{copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="stories" class="bg-slate-950 px-6 py-24 text-white lg:px-10 xl:px-16">
      <div class="mx-auto max-w-[1280px]">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-white/50">Patient Stories</p>
          <h2 class="font-display text-[clamp(36px,4vw,56px)] font-black leading-[1.15] tracking-[-0.02em]">Real People. <em class="text-goldbrand-300">Real Recoveries.</em></h2>
          <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-white/60">Hear from patients whose lives changed when they walked through our doors.</p>
        </div>
        <div class="grid gap-6 lg:grid-cols-3">
          {reviews.map(([initial, name, detail, quote]) => (
            <article class="rounded-2xl border border-white/10 bg-white/5 p-7 transition hover:bg-white/10">
              <div class="mb-4 tracking-[0.16em] text-goldbrand-300">★★★★★</div>
              <p class="text-[15px] italic leading-7 text-white/85">"{quote}"</p>
              <div class="mt-6 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-skybrand-500 to-skybrand-800 font-display font-bold">{initial}</div>
                <div>
                  <p class="text-sm font-semibold text-white">{name}</p>
                  <p class="text-xs text-white/45">{detail}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-12 grid overflow-hidden rounded-2xl bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
          {[
            ["5★", "Average Google Rating"],
            ["6+", "Clinic Locations"],
            ["1K+", "Patients Treated"],
            ["20+", "Years Serving Communities"],
          ].map(([number, label]) => (
            <div class="border-white/10 bg-white/5 p-8 text-center lg:border-l first:border-l-0">
              <p class="font-display text-4xl font-black text-white">{number}</p>
              <p class="mt-2 text-sm leading-5 text-white/50">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#FAF8F4] px-6 py-24 lg:px-10 xl:px-16">
      <div class="mx-auto max-w-[1280px]">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-skybrand-600">We're Here For You</p>
          <h2 class="font-display text-[clamp(32px,3vw,46px)] font-bold leading-[1.15] tracking-[-0.02em]">Whatever Brought You Here, You're in the <em class="text-skybrand-800">Right Place</em>.</h2>
          <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-slate-600">CarePT serves patients at every stage of the recovery journey. See yourself below.</p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {avatars.map((avatar) => (
            <article class="rounded-2xl border border-skybrand-900/10 bg-white p-8 transition hover:-translate-y-1.5 hover:shadow-card">
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-skybrand-50 text-skybrand-700 ring-1 ring-skybrand-100">
                {(() => {
                  const Icon = avatar.icon;
                  return <Icon class="h-6 w-6" />;
                })()}
              </div>
              <p class="mb-2 text-[11px] font-bold uppercase tracking-[0.12em] text-skybrand-600">{avatar.label}</p>
              <h3 class="font-display text-2xl text-slate-900">{avatar.name}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{avatar.copy}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {avatar.tags.map((tag) => <span class="rounded-full bg-skybrand-50 px-3 py-1 text-[11px] font-bold text-skybrand-800">{tag}</span>)}
              </div>
            </article>
          ))}
          <article class="rounded-2xl bg-gradient-to-br from-skybrand-800 to-skybrand-500 p-8 text-white shadow-card">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-white ring-1 ring-white/15">
              <CircleHelp class="h-6 w-6" />
            </div>
            <p class="mb-2 text-[11px] font-bold uppercase tracking-[0.12em] text-white/60">Not sure where to start?</p>
            <h3 class="font-display text-2xl">Let's figure it out together.</h3>
            <p class="mt-3 text-sm leading-7 text-white/80">Call us or request an appointment and we'll help you understand if CarePT is the right next step.</p>
            <a href="#appointment" class="mt-6 inline-flex min-h-12 items-center justify-center rounded-[10px] bg-goldbrand-500 px-6 text-sm font-bold text-slate-950">Request an Appointment</a>
          </article>
        </div>
      </div>
    </section>

    <section id="locations" class="mx-auto max-w-[1280px] px-6 py-24 lg:px-10 xl:px-16">
      <div class="mx-auto mb-14 max-w-3xl text-center">
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-skybrand-600">Find Your Location</p>
        <h2 class="font-display text-[clamp(32px,3vw,46px)] font-bold leading-[1.15] tracking-[-0.02em]">6 Locations. Always <em class="text-skybrand-800">Close to Home.</em></h2>
        <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-slate-600">Expert care at a location that actually fits your schedule.</p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {locations.map((location) => (
          <article class="overflow-hidden rounded-2xl border border-skybrand-900/15 bg-white transition hover:-translate-y-1 hover:border-skybrand-800/30 hover:shadow-card">
            <div class="relative aspect-[16/10] overflow-hidden bg-slate-100">
              <Image src={location.image} alt={location.alt} class="h-full w-full object-cover transition duration-500 hover:scale-105" />
              <div class="absolute left-4 top-4 flex h-10 w-10 items-center justify-center rounded-xl bg-white/90 text-skybrand-700 shadow-card backdrop-blur">
                <MapPin class="h-5 w-5" />
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl text-slate-900">{location.city}</h3>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-slate-400">{location.state}</p>
              <a href={`tel:${location.phone.replace(/\D/g, "")}`} class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-skybrand-600">
                <Phone class="h-4 w-4" />
                {location.phone}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="appointment" class="bg-gradient-to-br from-skybrand-800 to-skybrand-500 px-6 py-24 text-center text-white lg:px-10 xl:px-16">
      <div class="mx-auto max-w-3xl">
        <p class="mb-5 text-xs font-bold uppercase tracking-[0.12em] text-white/60">Start Your Recovery Today</p>
        <h2 class="font-display text-[clamp(36px,4vw,56px)] font-black leading-[1.15] tracking-[-0.02em]">Your <em class="text-goldbrand-300">Comeback Story</em><br />Starts Here.</h2>
        <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-8 text-white/75">Thousands of patients across Louisiana and Mississippi chose CarePT, and most of them wish they'd come sooner.</p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/" class="inline-flex min-h-14 items-center justify-center rounded-[10px] bg-goldbrand-500 px-9 text-base font-bold text-slate-950 transition hover:-translate-y-0.5 hover:bg-goldbrand-400">Request an Appointment</a>
          <a href="tel:+19852496111" class="inline-flex min-h-14 items-center justify-center gap-2 rounded-[10px] border-2 border-white/35 px-9 text-base font-semibold text-white transition hover:border-white hover:bg-white/10">
            <Phone class="h-5 w-5" />
            Call Us Instead
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="grid gap-10 bg-slate-900 px-6 py-14 text-white md:grid-cols-[2fr_1fr_1fr_1fr] lg:px-10 xl:px-16">
    <div>
      <Image src={logoWhite} alt="Care Physical Therapy" class="h-auto w-36" />
      <p class="mt-5 max-w-sm text-sm leading-7 text-white/45">Individualized, hands-on physical therapy care across 6 convenient locations. When you're here, you're family.</p>
      <p class="mt-4 font-display text-sm italic text-skybrand-300">"To inspire and empower through healing."</p>
    </div>
    <div>
      <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.12em] text-white/40">Services</h3>
      <div class="space-y-2 text-sm text-white/65">
        <a href="#conditions" class="block hover:text-white">Post-Surgical Recovery</a>

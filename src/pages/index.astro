  @media (min-width: 1024px) {
    .recovery-line {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      left: 12.5%;
      right: 12.5%;
      z-index: 0;
      height: 2px;
      overflow: hidden;
      border-radius: 999px;
      background: rgb(226 232 240);
    }

    .recovery-line::after {
      content: "";
      display: block;
      width: 100%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #1b4f8a, #3da8cf, #80be41);
      transform-origin: left;
      animation: recovery-progress 2.8s ease-out both;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .recovery-line::after {
      animation: none;
    }

  }

  @keyframes recovery-progress {
    from {
      transform: scaleX(0);
    }

    to {
      transform: scaleX(1);
    }
  }

</style>

  <script is:inline>
    (() => {
      const river = document.querySelector("#locations");
      if (!river) return;

      const feature = river.querySelector("#clinic-image");
      const title = river.querySelector("#clinic-title");
      const copy = river.querySelector("#clinic-copy");
      const buttons = Array.from(river.querySelectorAll(".location-item"));
      let active = feature?.getAttribute("src");

      const activeClasses = ["is-active", "border-skybrand-800", "bg-skybrand-800", "text-white", "shadow-card"];
      const inactiveClasses = ["border-slate-200", "bg-white/80", "text-slate-900"];

      function setButtonState(button, selected) {
        button.classList.toggle("is-active", selected);
        button.setAttribute("aria-pressed", String(selected));
        activeClasses.slice(1).forEach((className) => button.classList.toggle(className, selected));
        inactiveClasses.forEach((className) => button.classList.toggle(className, !selected));

        const detail = button.querySelector(".location-detail");
        const state = button.querySelector(".location-state");
        detail?.classList.toggle("text-skybrand-100", selected);
        detail?.classList.toggle("text-slate-500", !selected);
        state?.classList.toggle("text-skybrand-100", selected);
        state?.classList.toggle("text-skybrand-600", !selected);
        state?.classList.toggle("opacity-0", !selected);
        if (state) state.textContent = selected ? "Selected" : "View clinic";
      }

      function showClinic(button) {
        const next = button.dataset.image;
        buttons.forEach((candidate) => setButtonState(candidate, candidate === button));
        if (!next || next === active || !feature || !title || !copy) return;
        active = next;
        feature.setAttribute("src", next);
        feature.setAttribute("alt", button.dataset.alt || "");
        title.textContent = button.dataset.title || "";
        copy.textContent = button.dataset.copy || "";
      }

      buttons.forEach((button) => {
        button.addEventListener("mouseenter", () => showClinic(button));
        button.addEventListener("focus", () => showClinic(button));
        button.addEventListener("click", () => showClinic(button));
      });
    })();
  </script>

---
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import logo from "../assets/brand/logo.svg";
import logoWhite from "../assets/brand/logo-white.svg";
import franklintonClinic from "../assets/clinics/franklinton.jpg";
import hattiesburgClinic from "../assets/clinics/hattiesburg.jpg";
import ponchatoulaClinic from "../assets/clinics/ponchatoula.jpg";
import manualTherapyImage from "../assets/editorial/manual-therapy.jpeg";
import rehabSessionImage from "../assets/editorial/rehab-session.jpeg";
import treatmentRoomImage from "../assets/editorial/treatment-room.jpeg";
import billyCochranImage from "../assets/team/billy-cochran.png";
import brianCochranImage from "../assets/team/brian-cochran.jpg";
import byronBlackwellImage from "../assets/team/byron-blackwell.jpg";
import heathVillereImage from "../assets/team/heath-villere.jpg";
import jonathanMitchellImage from "../assets/team/jonathan-mitchell.jpg";
import kelvinMccainImage from "../assets/team/kelvin-mccain.jpg";
import ryanTateImage from "../assets/team/ryan-tate.jpg";
import stephanieElkinsImage from "../assets/team/stephanie-elkins.jpg";

const heroVideo = "/assets/video/physical-therapy-action.mp4";
const hasHeroVideo = existsSync(fileURLToPath(new URL("../../public/assets/video/physical-therapy-action.mp4", import.meta.url)));

const insuranceCarriers = [
  "Medicare",
  "Medicaid",
  "Blue Cross Blue Shield",
  "UnitedHealthcare",
  "Aetna",
  "Cigna",
  "Workers' Compensation",
  "Humana",
  "Tricare",
  "Most major carriers accepted",
];

const conditions = [
  "Back, hip pain & sciatica",
  "Neck pain",
  "Shoulder injuries",
  "Post-surgical rehab",
  "Balance & dizziness",
  "Chronic pain",
  "Foot & ankle diagnoses",
  "Muscle strains & sprains",
];

const clinics = [
  {
    title: "Hattiesburg, MS",
    detail: "CarePT clinic serving south Mississippi.",
    copy: "One of six CarePT clinics serving patients across south Mississippi.",
    image: hattiesburgClinic,
    alt: "CarePT Hattiesburg clinic exterior",
  },
  {
    title: "Covington, LA",
    detail: "129 Corporate Dr. · (985) 249-6111",
    copy: "129 Corporate Dr. · (985) 249-6111",
    image: treatmentRoomImage,
    alt: "CarePT treatment room",
  },
  {
    title: "Bogalusa, LA",
    detail: "1202 Sunset Dr. · (985) 735-1426",
    copy: "1202 Sunset Dr. · (985) 735-1426",
    image: manualTherapyImage,
    alt: "CarePT hands-on therapy",
  },
  {
    title: "Franklinton, LA",
    detail: "44626 J Meadie Knight Dr. · (985) 795-1746",
    copy: "44626 J Meadie Knight Drive · (985) 795-1746",
    image: franklintonClinic,
    alt: "CarePT Franklinton clinic",
  },
  {
    title: "Ponchatoula, LA",
    detail: "1625 Hwy 51 Suite C · (985) 386-2222",
    copy: "1625 Hwy 51 Suite C · (985) 386-2222",
    image: ponchatoulaClinic,
    alt: "CarePT Ponchatoula clinic",
  },
  {
    title: "Sumrall, MS",
    detail: "4877 Mississippi 589 · (601) 758-3333",
    copy: "4877 Mississippi 589 · (601) 758-3333",
    image: rehabSessionImage,
    alt: "CarePT rehab session",
  },
];

const team = [
  { name: "Byron Blackwell", role: "MPT — Bogalusa", image: byronBlackwellImage },
  { name: "Brian Cochran", role: "PT, MCMT — Covington", image: brianCochranImage },
  { name: "C. Ryan Tate", role: "DPT — Covington", image: ryanTateImage },
  { name: "Heath Villere", role: "DPT — Covington", image: heathVillereImage },
  { name: "Kelvin McCain", role: "PT — Franklinton", image: kelvinMccainImage },
  { name: "Jonathan Mitchell", role: "PT, ATC — Ponchatoula", image: jonathanMitchellImage },
  { name: "Billy Cochran", role: "PT, CSCS — Hattiesburg", image: billyCochranImage },
  { name: "Stephanie Elkins", role: "DPT — Sumrall", image: stephanieElkinsImage },
];
---

<BaseLayout
  title="CarePT Physical Therapy"
  description="CarePT helps patients move through pain, surgery, injury, and uncertainty with hands-on treatment, clear plans, and attentive care."
>
  <div class="page">
    <header class="nav is-at-top" data-site-nav>
      <div class="shell nav-inner">
        <a href="#" aria-label="CarePT home"><Image class="logo" src={logo} alt="Care Physical Therapy" /></a>
        <nav class="links" aria-label="Primary">
          <a href="#services">Services</a>
          <a href="#conditions">Conditions</a>
          <a href="#locations">Locations</a>
          <a href="#team">Team</a>
          <a href="#appointment">Appointment</a>
        </nav>
        <div class="actions">
          <a class="btn" href="tel:+19852496111">Call CarePT</a>
          <a class="btn primary" href="#appointment">Request a visit</a>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-layout">
          <div class="hero-copy-panel">
            <p class="eyebrow">Care Physical Therapy</p>
            <h1>Get Your <span class="accent-word">Life</span> Back<br>Expert Care, Close to Home</h1>
            <p class="lead">CarePT helps patients move through pain, surgery, injury, and uncertainty with hands-on treatment, clear plans, and the kind of attention that makes recovery feel possible again.</p>
            <div class="hero-ctas">
              <a class="btn primary" href="#appointment">Request an appointment</a>
              <a class="btn" href="#locations">Find a clinic</a>
            </div>
          </div>
          <div class="hero-media">
            <figure class="hero-photo">
              {hasHeroVideo ? (
                <video autoplay muted loop playsinline preload="metadata" poster={rehabSessionImage.src} aria-label="Physical therapy session in progress">
                  <source src={heroVideo} type="video/mp4" />
                </video>
              ) : (
                <Image src={rehabSessionImage} alt="CarePT therapist assisting a patient" />
              )}
            </figure>
            <aside class="floating-panel">
              <span>Our Mission</span>
              <p>Inspired to heal. Empowered to live.</p>
            </aside>
          </div>
        </div>
      </section>

      <div class="trust-strip" aria-label="Accepted insurance carriers">
        <span class="trust-label-badge" aria-hidden="true">Insurance accepted</span>
        <div class="trust-track">
          <div class="trust-list" aria-hidden="true">
            {[...insuranceCarriers, ...insuranceCarriers].map((carrier) => (
              <>
                <span class="trust-item">{carrier}</span><span class="trust-sep"></span>
              </>
            ))}
          </div>
        </div>
      </div>

      <section class="conditions" id="conditions">
        <div class="shell conditions-layout">
          <div class="portrait-stack">
            <figure class="image-a"><Image src={manualTherapyImage} alt="Therapist guiding a patient through hands-on care" /></figure>
            <figure class="image-b"><Image src={treatmentRoomImage} alt="CarePT treatment room" /></figure>
          </div>
          <div>
            <p class="eyebrow">First-time patients</p>
            <h2>If physical therapy failed you before, this should feel different.</h2>
            <p class="section-copy">Rushed appointments and generic exercise sheets are not enough when pain is changing the way you work, sleep, walk, or care for your family. CarePT begins with a comprehensive evaluation, then builds a plan around the way your body moves and the outcome you need back.</p>
            <div class="cond-grid" aria-label="Common conditions we treat">
              {conditions.map((condition) => (
                <div class="cond-item"><span class="cond-dot"></span>{condition}</div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="services" id="services">
        <div class="shell">
          <div class="services-head">
            <p class="eyebrow">Expert services</p>
            <h2>Hands-on expertise. No cookie-cutter care.</h2>
            <p>CarePT combines manual therapy, guided strengthening, movement retraining, and practical home programs so patients understand what is happening and what progress should feel like.</p>
          </div>
          <div class="service-cards">
            <article class="service-card">
              <div class="sc-image"><Image src={manualTherapyImage} alt="Manual therapy session" /></div>
              <div class="sc-body">
                <span class="sc-tag">Hands-on care</span>
                <h3>Manual Therapy</h3>
                <p>Skilled joint mobilization and soft-tissue techniques that restore movement and reduce pain at the source.</p>
              </div>
            </article>
            <article class="service-card">
              <div class="sc-image"><Image src={rehabSessionImage} alt="Rehabilitation session" /></div>
              <div class="sc-body">
                <span class="sc-tag">Guided exercise</span>
                <h3>Therapeutic Rehabilitation</h3>
                <p>Individual progressions for strength, mobility, and control - from first session to confident independence.</p>
              </div>
            </article>
            <article class="service-card">
              <div class="sc-image"><Image src={treatmentRoomImage} alt="CarePT treatment room" /></div>
              <div class="sc-body">
                <span class="sc-tag">Specialized programs</span>
                <h3>Aquatic &amp; Specialized Care</h3>
                <p>Aquatic therapy, dry needling, gait retraining, and balance programs tailored to your clinical picture.</p>
              </div>
            </article>
          </div>
          <div class="service-extras">
            <article class="service-card service-extra">
              <div class="sc-image"><Image src={manualTherapyImage} alt="Aquatic therapy session" /></div>
              <div class="sc-body">
                <span class="sc-tag">Low impact</span>
                <h3>Aquatic Therapy</h3>
                <p>Low-impact movement that rebuilds joint tolerance without aggravating pain.</p>
              </div>
            </article>
            <article class="service-card service-extra">
              <div class="sc-image"><Image src={rehabSessionImage} alt="Gait and balance training" /></div>
              <div class="sc-body">
                <span class="sc-tag">Steady movement</span>
                <h3>Gait &amp; Balance Training</h3>
                <p>Practical retraining for steadier walking, fall prevention, and everyday independence.</p>
              </div>
            </article>
            <article class="service-card service-extra">
              <div class="sc-image"><Image src={treatmentRoomImage} alt="Trigger point dry needling treatment room" /></div>
              <div class="sc-body">
                <span class="sc-tag">Targeted care</span>
                <h3>Trigger Point Dry Needling</h3>
                <p>Targeted treatment for muscle tension and referred pain when clinically appropriate.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="referral">
        <div class="shell referral-wrap">
          <div class="referral-copy">
            <p class="eyebrow">Referral-friendly care</p>
            <h2>Trusted by physicians.</h2>
            <p class="section-copy">A strong referral experience depends on clarity: the patient understands the plan, the therapist tracks what is changing, and the physician can trust that care is progressing with purpose.</p>
            <div class="care-path">
              <article class="path-point">
                <span>Evaluate</span>
                <strong>The whole picture</strong>
                <p>Pain, movement, work demands, sleep, surgery history, and patient goals.</p>
              </article>
              <article class="path-point">
                <span>Treat</span>
                <strong>With intention</strong>
                <p>Hands-on care, targeted exercise, and education patients can actually use.</p>
              </article>
              <article class="path-point">
                <span>Restore</span>
                <strong>Daily confidence</strong>
                <p>Less pain, steadier movement, and a body patients trust again.</p>
              </article>
            </div>
          </div>
          <aside class="quote-card">
            <div class="quote-card-bg">
              <Image src={manualTherapyImage} alt="" aria-hidden="true" />
            </div>
            <span class="quote-kicker">Patient outcome</span>
            <blockquote>"I won't be having surgery and I give the credit to my friends at CARE Physical Therapy."</blockquote>
            <cite>Patient testimonial</cite>
          </aside>
        </div>
      </section>

      <section class="locations" id="locations">
        <div class="shell">
          <div class="locations-top">
            <p class="eyebrow">Six convenient locations</p>
            <h2>Find the CarePT clinic closest to your recovery.</h2>
            <p>CarePT serves communities across Louisiana and Mississippi with six clinics, clear contact points, and a consistent clinical standard from one location to the next.</p>
          </div>
          <div class="location-river">
            <figure class="clinic-feature">
              <Image id="clinic-image" src={hattiesburgClinic} alt="CarePT Hattiesburg clinic exterior" />
              <figcaption class="clinic-caption">
                <h3 id="clinic-title">Hattiesburg, MS</h3>
                <p id="clinic-copy">One of six CarePT clinics serving patients across south Mississippi.</p>
              </figcaption>
            </figure>
            <div class="location-list">
              {clinics.map((clinic, index) => (
                <button
                  class:list={["location-item", { "is-active": index === 0 }]}
                  type="button"
                  data-title={clinic.title}
                  data-copy={clinic.copy}
                  data-image={clinic.image.src}
                  data-alt={clinic.alt}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span class="location-name">{clinic.title}</span>
                  <span class="location-detail">{clinic.detail}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="team" id="team">
        <div class="shell">
          <div class="team-head">
            <div>
              <p class="eyebrow">Meet the clinicians</p>
              <h2>Expertise with the warmth that makes recovery feel human.</h2>
            </div>
            <p class="section-copy team-copy">CarePT's clinicians bring licensed expertise and local trust to the treatment room, translating clinical plans into progress patients can feel.</p>
          </div>
          <div class="team-scroll">
            {team.map((member) => (
              <article class="person">
                <Image src={member.image} alt={member.name} />
                <div><h3>{member.name}</h3><p>{member.role}</p></div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="appointment" id="appointment">
        <div class="shell appointment-layout">
          <div>
            <p class="eyebrow">Request an appointment</p>
            <h2>Start with a team that sees the whole picture.</h2>
            <p class="section-copy">Tell us where you are, what hurts, and which clinic fits your week. CarePT will help you take the next step toward pain relief, better movement, and more confidence.</p>
            <div class="appt-promises">
              <div class="appt-promise"><strong>Whole-body treatment</strong>Care that connects your symptoms, goals, habits, and daily demands.</div>
              <div class="appt-promise"><strong>Trusted regional access</strong>Six clinics across Louisiana and Mississippi with one clinical standard.</div>
            </div>
          </div>
          <form class="form-card" name="appointment" method="POST" data-netlify="true" netlify-honeypot="bot-field" aria-label="Appointment request">
            <input type="hidden" name="form-name" value="appointment" />
            <input type="hidden" name="bot-field" />
            <div class="form-grid">
              <div><label for="first-name">First name</label><input id="first-name" name="first-name" autocomplete="given-name" required /></div>
              <div><label for="last-name">Last name</label><input id="last-name" name="last-name" autocomplete="family-name" required /></div>
              <div><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required /></div>
              <div><label for="phone">Phone</label><input id="phone" name="phone" type="tel" autocomplete="tel" required /></div>
              <div><label for="location">Preferred clinic</label><select id="location" name="preferred-clinic"><option>Covington, LA</option><option>Bogalusa, LA</option><option>Franklinton, LA</option><option>Ponchatoula, LA</option><option>Hattiesburg, MS</option><option>Sumrall, MS</option></select></div>
              <div><label for="patient">New patient?</label><select id="patient" name="patient-status"><option>Yes</option><option>No</option><option>Not sure</option></select></div>
              <div class="wide"><label for="notes">What do you need help with?</label><textarea id="notes" name="message"></textarea></div>
            </div>
            <button class="btn primary" type="submit">Send appointment request</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell">
        <div class="footer-grid">
          <div>
            <Image class="logo" src={logoWhite} alt="Care Physical Therapy" />
            <p>Individualized, hands-on physical therapy for pain, mobility, strength, balance, and confidence.</p>
          </div>
          <div><h3>Care</h3><p><a href="#conditions">Conditions</a></p><p><a href="#services">Services</a></p><p><a href="#appointment">Appointments</a></p></div>
          <div><h3>Clinics</h3><p>Covington · Bogalusa · Franklinton</p><p>Ponchatoula · Hattiesburg · Sumrall</p></div>
          <div><h3>Contact</h3><p><a href="tel:+19852496111">(985) 249-6111</a></p><p><a href="#appointment">Request a visit</a></p></div>
        </div>
        <div class="footer-base">
          <span>© 2026 Care Physical Therapy. All rights reserved.</span>
          <span>Louisiana &amp; Mississippi</span>
        </div>
      </div>
    </footer>
  </div>

  <script is:inline>
    (() => {
      const nav = document.querySelector("[data-site-nav]");
      if (!nav) return;

      let ticking = false;

      function updateNavState() {
        const atTop = window.scrollY <= 8;
        nav.classList.toggle("is-at-top", atTop);
        nav.classList.toggle("is-scrolled", !atTop);
        ticking = false;
      }

      updateNavState();
      window.addEventListener("scroll", () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateNavState);
      }, { passive: true });
    })();

    (() => {
      const river = document.querySelector(".location-river");
      if (!river) return;

      const feature = river.querySelector(".clinic-feature");
      const image = river.querySelector("#clinic-image");
      const title = river.querySelector("#clinic-title");
      const copy = river.querySelector("#clinic-copy");
      const buttons = Array.from(river.querySelectorAll(".location-item"));
      let active = image?.getAttribute("src");

      function showClinic(btn) {
        const next = btn.dataset.image;
        buttons.forEach((button) => {
          const selected = button === btn;
          button.classList.toggle("is-active", selected);
          button.setAttribute("aria-pressed", String(selected));
        });

        if (!next || next === active || !feature || !image || !title || !copy) return;
        active = next;
        feature.classList.add("is-changing");
        window.setTimeout(() => {
          image.src = next;
          image.alt = btn.dataset.alt || "";
          title.textContent = btn.dataset.title || "";
          copy.textContent = btn.dataset.copy || "";
          feature.classList.remove("is-changing");
        }, 140);
      }

      buttons.forEach((btn) => {
        btn.addEventListener("mouseenter", () => showClinic(btn));
        btn.addEventListener("focus", () => showClinic(btn));
        btn.addEventListener("click", () => showClinic(btn));
      });
    })();
  </script>
</BaseLayout>

<style>
  :global(:root) {
    --bg: oklch(98.5% 0.006 236);
    --surface: oklch(100% 0 0);
    --wash: oklch(97% 0.014 232);
    --fg: oklch(18% 0.044 258);
    --muted: oklch(49% 0.028 246);
    --border: oklch(91% 0.014 234);
    --brand: #2B9DCC;
    --navy: #193F6F;
    --navy-deep: oklch(15% 0.052 258);
    --accent: oklch(74% 0.13 82);
    --font-display: "Iowan Old Style", "Charter", Georgia, serif;
    --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }

  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font: 16px/1.6 var(--font-body);
    text-rendering: optimizeLegibility;
  }
  :global(body::before) {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse at 14% 8%, color-mix(in oklch, var(--brand) 9%, transparent), transparent 32rem),
      linear-gradient(180deg, var(--wash) 0%, var(--bg) 38rem);
  }
  :global(img) { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button, input, select, textarea { font: inherit; }
  figure { margin: 0; }
  .page { overflow: hidden; padding-top: 78px; }
  .shell { width: min(1200px, calc(100% - 48px)); margin: 0 auto; }

  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 20;
    border-bottom: 1px solid color-mix(in oklch, var(--border) 70%, transparent);
    background: color-mix(in oklch, white 88%, transparent);
    backdrop-filter: blur(20px);
    transition: background 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }
  .nav.is-at-top {
    border-bottom-color: color-mix(in oklch, var(--border) 45%, transparent);
    background: color-mix(in oklch, white 82%, transparent);
    box-shadow: none;
  }
  .nav.is-scrolled {
    border-bottom-color: color-mix(in oklch, var(--border) 86%, transparent);
    background: color-mix(in oklch, white 94%, transparent);
    box-shadow: 0 12px 34px color-mix(in oklch, var(--navy-deep) 9%, transparent);
  }
  .nav-inner {
    height: 78px; display: flex; align-items: center; justify-content: space-between; gap: 30px;
    transition: height 180ms ease;
  }
  .nav .logo { width: 152px; height: auto; transition: width 180ms ease; }
  .nav.is-scrolled .nav-inner { height: 62px; }
  .nav.is-scrolled .logo { width: 126px; }
  .links { display: flex; gap: 32px; align-items: center; color: var(--muted); font-size: 13.5px; font-weight: 700; }
  .links a { transition: color 160ms; }
  .links a:hover { color: var(--fg); }
  .actions { display: flex; gap: 10px; align-items: center; }
  .btn {
    min-height: 44px; display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--border); border-radius: 999px; padding: 0 22px;
    background: white; color: var(--fg); font-size: 13.5px; font-weight: 800;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease, min-height 180ms ease, padding 180ms ease;
  }
  .nav.is-scrolled .btn { min-height: 38px; padding: 0 18px; }
  .btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px color-mix(in oklch, var(--brand) 14%, transparent); border-color: color-mix(in oklch, var(--brand) 44%, var(--border)); }
  .btn.primary { border-color: var(--navy); background: var(--navy); color: white; }
  .btn.primary:hover { box-shadow: 0 6px 22px color-mix(in oklch, var(--navy-deep) 28%, transparent); }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 11px;
    margin: 0 0 20px; color: var(--navy);
    font: 850 12px/1 var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;
  }
  .eyebrow::before { content: ""; width: 26px; height: 2.5px; border-radius: 999px; background: var(--brand); flex: 0 0 auto; }
  h1, h2, h3, h4, p { margin-top: 0; }

  .hero { padding: 0; min-height: calc(100svh - 78px); }
  .hero-layout {
    width: 100%; max-width: none; margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0; align-items: stretch; min-height: calc(100svh - 78px);
  }
  .hero-copy-panel {
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(60px, 8vw, 108px) 72px clamp(60px, 8vw, 108px) calc((100vw - min(1200px, calc(100vw - 48px))) / 2 + 24px);
  }
  h1 { max-width: 640px; margin-bottom: 26px; font: 760 clamp(46px, 5vw, 66px)/0.94 var(--font-display); letter-spacing: -0.038em; text-wrap: balance; }
  .accent-word { color: var(--accent); }
  .lead { max-width: 580px; margin-bottom: 32px; color: var(--muted); font-size: 17px; line-height: 1.62; text-wrap: pretty; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 0; }

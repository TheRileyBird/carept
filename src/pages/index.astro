---
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { Image } from "astro:assets";
import {
  ArrowRight,
  Building2,
  CalendarDays,
  CircleCheckBig,
  Clock3,
  Mail,
  MapPin,
  Phone,
  Quote,
  ShieldCheck,
  Star,
  Users,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import logoWhite from "../assets/brand/logo-white.svg";
import franklintonClinic from "../assets/clinics/franklinton.jpg";
import hattiesburgClinic from "../assets/clinics/hattiesburg.jpg";
import ponchatoulaClinic from "../assets/clinics/ponchatoula.jpg";
import manualTherapyImage from "../assets/editorial/manual-therapy.jpeg";
import rehabSessionImage from "../assets/editorial/rehab-session.jpeg";
import treatmentRoomImage from "../assets/editorial/treatment-room.jpeg";
import billyCochranImage from "../assets/team/billy-cochran.png";
import brianCochranImage from "../assets/team/brian-cochran.jpg";
import byronBlackwellImage from "../assets/team/byron-blackwell.jpg";
import heathVillereImage from "../assets/team/heath-villere.jpg";
import jonathanMitchellImage from "../assets/team/jonathan-mitchell.jpg";
import kelvinMccainImage from "../assets/team/kelvin-mccain.jpg";
import ryanTateImage from "../assets/team/ryan-tate.jpg";
import stephanieElkinsImage from "../assets/team/stephanie-elkins.jpg";

const heroVideo = "/assets/video/physical-therapy-action.mp4";
const hasHeroVideo = existsSync(fileURLToPath(new URL("../../public/assets/video/physical-therapy-action.mp4", import.meta.url)));

const insuranceCarriers = [
  "Medicare",
  "Medicaid",
  "Blue Cross Blue Shield",
  "UnitedHealthcare",
  "Aetna",
  "Cigna",
  "Workers' Compensation",
  "Humana",
  "Tricare",
  "Most major carriers accepted",
];

const conditions = [
  "Back, hip pain & sciatica",
  "Neck pain",
  "Shoulder injuries",
  "Post-surgical rehab",
  "Balance & dizziness",
  "Chronic pain",
  "Foot & ankle diagnoses",
  "Muscle strains & sprains",
];

const clinics = [
  {
    title: "Hattiesburg, MS",
    detail: "CarePT clinic serving south Mississippi.",
    copy: "One of six CarePT clinics serving patients across south Mississippi.",
    image: hattiesburgClinic,
    alt: "CarePT Hattiesburg clinic exterior",
    phone: "(601) 296-0199",
    address: "52 98 Place Blvd.",
  },
  {
    title: "Covington, LA",
    detail: "129 Corporate Dr. · (985) 249-6111",
    copy: "129 Corporate Dr. · (985) 249-6111",
    image: treatmentRoomImage,
    alt: "CarePT treatment room",
    phone: "(985) 249-6111",
    address: "129 Corporate Dr.",
  },
  {
    title: "Bogalusa, LA",
    detail: "1202 Sunset Dr. · (985) 735-1426",
    copy: "1202 Sunset Dr. · (985) 735-1426",
    image: manualTherapyImage,
    alt: "CarePT hands-on therapy",
    phone: "(985) 735-1426",
    address: "1202 Sunset Dr.",
  },
  {
    title: "Franklinton, LA",
    detail: "44626 J Meadie Knight Dr. · (985) 795-1746",
    copy: "44626 J Meadie Knight Drive · (985) 795-1746",
    image: franklintonClinic,
    alt: "CarePT Franklinton clinic",
    phone: "(985) 795-1746",
    address: "44626 J Meadie Knight Drive",
  },
  {
    title: "Ponchatoula, LA",
    detail: "1625 Hwy 51 Suite C · (985) 386-2222",
    copy: "1625 Hwy 51 Suite C · (985) 386-2222",
    image: ponchatoulaClinic,
    alt: "CarePT Ponchatoula clinic",
    phone: "(985) 386-2222",
    address: "1625 Hwy 51 Suite C",
  },
  {
    title: "Sumrall, MS",
    detail: "4877 Mississippi 589 · (601) 758-3333",
    copy: "4877 Mississippi 589 · (601) 758-3333",
    image: rehabSessionImage,
    alt: "CarePT rehab session",
    phone: "(601) 758-3333",
    address: "4877 Mississippi 589",
  },
];

const team = [
  { name: "Byron Blackwell", role: "MPT — Bogalusa", image: byronBlackwellImage },
  { name: "Brian Cochran", role: "PT, MCMT — Covington", image: brianCochranImage },
  { name: "C. Ryan Tate", role: "DPT — Covington", image: ryanTateImage },
  { name: "Heath Villere", role: "DPT — Covington", image: heathVillereImage },
  { name: "Kelvin McCain", role: "PT — Franklinton", image: kelvinMccainImage },
  { name: "Jonathan Mitchell", role: "PT, ATC — Ponchatoula", image: jonathanMitchellImage },
  { name: "Billy Cochran", role: "PT, CSCS — Hattiesburg", image: billyCochranImage },
  { name: "Stephanie Elkins", role: "DPT — Sumrall", image: stephanieElkinsImage },
];

const serviceCards = [
  {
    image: manualTherapyImage,
    alt: "Manual therapy session",
    tag: "Hands-on care",
    title: "Manual Therapy",
    copy: "Skilled joint mobilization and soft-tissue techniques that restore movement and reduce pain at the source.",
  },
  {
    image: rehabSessionImage,
    alt: "Rehabilitation session",
    tag: "Guided exercise",
    title: "Therapeutic Rehabilitation",
    copy: "Individual progressions for strength, mobility, and control from first session to confident independence.",
  },
  {
    image: treatmentRoomImage,
    alt: "CarePT treatment room",
    tag: "Specialized programs",
    title: "Aquatic & Specialized Care",
    copy: "Aquatic therapy, dry needling, gait retraining, and balance programs tailored to your clinical picture.",
  },
  {
    image: manualTherapyImage,
    alt: "Aquatic therapy session",
    tag: "Low impact",
    title: "Aquatic Therapy",
    copy: "Low-impact movement that rebuilds joint tolerance without aggravating pain.",
  },
  {
    image: rehabSessionImage,
    alt: "Gait and balance training",
    tag: "Steady movement",
    title: "Gait & Balance Training",
    copy: "Practical retraining for steadier walking, fall prevention, and everyday independence.",
  },
  {
    image: treatmentRoomImage,
    alt: "Trigger point dry needling treatment room",
    tag: "Targeted care",
    title: "Trigger Point Dry Needling",
    copy: "Targeted treatment for muscle tension and referred pain when clinically appropriate.",
  },
];
---

<BaseLayout
  title="CarePT Physical Therapy"
  description="CarePT helps patients move through pain, surgery, injury, and uncertainty with hands-on treatment, clear plans, and attentive care."
>
  <div class="overflow-hidden bg-white pt-[78px] text-slate-900">
    <SiteHeader />

    <main>
      <section class="grid min-h-[calc(100svh-78px)] overflow-hidden bg-gradient-to-b from-skybrand-200 via-skybrand-50 to-white lg:grid-cols-2">
        <div class="flex flex-col justify-center px-6 py-20 sm:px-10 lg:px-[calc((100vw-min(1280px,100vw-48px))/2+24px)] lg:pr-16">
          <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
            Care Physical Therapy
          </p>
          <h1 class="max-w-2xl font-display text-[clamp(46px,5vw,66px)] font-black leading-[0.94] tracking-[-0.038em] text-slate-950">
            Get Your <span class="animate-animated-text bg-[linear-gradient(-45deg,#80be41,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">Life</span> Back<br />
            Expert Care, Close to Home
          </h1>
          <p class="mt-7 max-w-xl text-[17px] leading-8 text-slate-700">
            CarePT helps patients move through pain, surgery, injury, and uncertainty with hands-on treatment, clear plans,
            and the kind of attention that makes recovery feel possible again.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#appointment" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-skybrand-800 px-6 text-sm font-extrabold text-white shadow-card transition hover:-translate-y-0.5 hover:bg-skybrand-900">
              <CalendarDays class="h-4 w-4" />
              Request an appointment
            </a>
            <a href="#locations" class="inline-flex min-h-11 items-center justify-center rounded-full border border-skybrand-800/20 bg-white/70 px-6 text-sm font-extrabold text-skybrand-900 transition hover:-translate-y-0.5 hover:border-skybrand-800/40 hover:bg-white">
              Find a clinic
            </a>
          </div>
        </div>

        <div class="relative min-h-[520px] overflow-hidden bg-slate-900 lg:min-h-[calc(100svh-78px)]">
          {hasHeroVideo ? (
            <video autoplay muted loop playsinline preload="metadata" poster={rehabSessionImage.src} aria-label="Physical therapy session in progress" class="absolute inset-0 h-full w-full object-cover">
              <source src={heroVideo} type="video/mp4" />
            </video>
          ) : (
            <Image src={rehabSessionImage} alt="CarePT therapist assisting a patient" class="absolute inset-0 h-full w-full object-cover" />
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/10 to-transparent"></div>
          <aside class="absolute bottom-6 left-6 right-6 rounded-2xl border border-white/15 bg-slate-950/75 p-6 text-white shadow-elevated backdrop-blur md:left-8 md:right-auto md:max-w-sm">
            <span class="text-[11px] font-black uppercase tracking-[0.12em] text-skybrand-200">Our Mission</span>
            <p class="mt-2 font-display text-2xl font-bold leading-tight">Inspired to heal. Empowered to live.</p>
          </aside>
        </div>
      </section>

      <section class="relative overflow-hidden bg-slate-950" aria-label="Accepted insurance carriers">
        <span class="absolute left-6 top-1/2 z-10 flex -translate-y-1/2 items-center gap-2 rounded-full border border-skybrand-500/40 bg-slate-950 px-4 py-2 text-[11px] font-black uppercase tracking-[0.12em] text-skybrand-100 shadow-[0_0_0_8px_rgb(2_6_23),16px_0_24px_rgb(2_6_23)]">
          <span class="h-2 w-2 rounded-full bg-skybrand-400"></span>
          Insurance accepted
        </span>
        <div class="flex min-h-[58px] items-center overflow-hidden pl-48">
          <div class="flex w-max animate-marquee items-center motion-reduce:animate-none">
            {[...insuranceCarriers, ...insuranceCarriers].map((carrier) => (
              <>
                <span class="whitespace-nowrap px-7 text-[13px] font-bold text-white/70">{carrier}</span>
                <span class="h-1 w-1 shrink-0 rounded-full bg-skybrand-400/70"></span>
              </>
            ))}
          </div>
        </div>
      </section>

      <section id="conditions" class="border-b border-slate-200 bg-white px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto grid max-w-[1280px] items-center gap-16 lg:grid-cols-[0.82fr_1fr]">
          <div class="relative min-h-[420px] lg:min-h-[540px]">
            <figure class="absolute inset-y-0 left-0 right-16 overflow-hidden rounded-[110px_28px_28px_28px] bg-slate-100 shadow-elevated">
              <Image src={manualTherapyImage} alt="Therapist guiding a patient through hands-on care" class="h-full w-full object-cover" />
            </figure>
            <figure class="absolute bottom-0 right-0 w-[52%] overflow-hidden rounded-[28px_28px_90px_28px] border-[10px] border-white bg-slate-100 shadow-elevated">
              <Image src={treatmentRoomImage} alt="CarePT treatment room" class="aspect-[0.84] h-full w-full object-cover" />
            </figure>
          </div>
          <div>
            <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
              First-time patients
            </p>
            <h2 class="max-w-xl font-display text-[clamp(36px,4vw,48px)] font-bold leading-[0.98] tracking-[-0.035em] text-slate-950">
              If physical therapy failed you before, this should feel different.
            </h2>
            <p class="mt-5 max-w-xl text-[17px] leading-8 text-slate-600">
              Rushed appointments and generic exercise sheets are not enough when pain is changing the way you work,
              sleep, walk, or care for your family. CarePT begins with a comprehensive evaluation, then builds a plan
              around the way your body moves and the outcome you need back.
            </p>
            <div class="mt-8 grid gap-3 sm:grid-cols-2" aria-label="Common conditions we treat">
              {conditions.map((condition) => (
                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold leading-tight text-slate-800">
                  <span class="h-2 w-2 shrink-0 rounded-full bg-skybrand-500"></span>
                  {condition}
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="bg-slate-50 px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="mx-auto mb-14 max-w-4xl text-center">
            <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700">Expert services</p>
            <h2 class="font-display text-[clamp(38px,5vw,68px)] font-bold leading-[0.98] tracking-[-0.035em] text-slate-950">
              Hands-on expertise. No cookie-cutter care.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-8 text-slate-600">
              CarePT combines manual therapy, guided strengthening, movement retraining, and practical home programs so
              patients understand what is happening and what progress should feel like.
            </p>
          </div>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {serviceCards.map((service) => (
              <article class="overflow-hidden rounded-[26px] border border-slate-200 bg-white shadow-card transition hover:-translate-y-1 hover:shadow-elevated">
                <div class="aspect-[16/10] overflow-hidden">
                  <Image src={service.image} alt={service.alt} class="h-full w-full object-cover transition duration-500 hover:scale-105" />
                </div>
                <div class="p-7">
                  <span class="inline-flex rounded-full border border-skybrand-200 bg-skybrand-50 px-3 py-1 text-[11px] font-black uppercase tracking-[0.1em] text-skybrand-800">
                    {service.tag}
                  </span>
                  <h3 class="mt-4 font-display text-2xl font-bold leading-tight text-slate-950">{service.title}</h3>
                  <p class="mt-3 text-[14.5px] leading-7 text-slate-600">{service.copy}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-white px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto grid max-w-[1280px] items-center gap-16 lg:grid-cols-[0.88fr_1fr]">
          <div>
            <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
              Referral-friendly care
            </p>
            <h2 class="font-display text-[clamp(38px,5vw,68px)] font-bold leading-[0.98] tracking-[-0.035em] text-slate-950">
              Trusted by physicians.
            </h2>
            <p class="mt-5 max-w-xl text-[17px] leading-8 text-slate-600">
              A strong referral experience depends on clarity: the patient understands the plan, the therapist tracks
              what is changing, and the physician can trust that care is progressing with purpose.
            </p>
            <div class="mt-9 divide-y divide-skybrand-100 border-y border-skybrand-100">
              {[
                ["Evaluate", "The whole picture", "Pain, movement, work demands, sleep, surgery history, and patient goals."],
                ["Treat", "With intention", "Hands-on care, targeted exercise, and education patients can actually use."],
                ["Restore", "Daily confidence", "Less pain, steadier movement, and a body patients trust again."],
              ].map(([label, title, copy]) => (
                <article class="grid grid-cols-[30px_1fr] gap-x-4 py-5">
                  <span class="mt-1 h-3 w-3 rounded-full bg-skybrand-500 shadow-[0_0_0_7px_rgba(224,242,254,1)]"></span>
                  <div>
                    <span class="text-[11px] font-black uppercase tracking-[0.08em] text-skybrand-600">{label}</span>
                    <strong class="mt-1 block font-display text-2xl leading-tight text-slate-950">{title}</strong>
                    <p class="mt-2 text-sm leading-6 text-slate-600">{copy}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
          <aside class="relative flex min-h-[520px] flex-col justify-end overflow-hidden rounded-[48px_48px_48px_150px] p-8 text-white shadow-elevated sm:p-12">
            <Image src={manualTherapyImage} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" />
            <div class="absolute inset-0 bg-gradient-to-b from-slate-950/20 to-slate-950/85"></div>
            <div class="relative">
              <span class="inline-flex rounded-full bg-white/15 px-3 py-2 text-[11px] font-black uppercase tracking-[0.1em] text-skybrand-100 backdrop-blur">Patient outcome</span>
              <Quote class="mt-8 h-10 w-10 text-white/30" />
              <blockquote class="mt-4 max-w-xl font-display text-[clamp(30px,4vw,56px)] font-bold leading-none tracking-[-0.03em]">
                "I won't be having surgery and I give the credit to my friends at CARE Physical Therapy."
              </blockquote>
              <cite class="mt-5 block text-sm not-italic text-skybrand-100">Patient testimonial</cite>
            </div>
          </aside>
        </div>
      </section>

      <section id="locations" class="bg-slate-50 px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="mx-auto mb-14 max-w-4xl text-center">
            <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700">Six convenient locations</p>
            <h2 class="font-display text-[clamp(40px,5vw,58px)] font-bold leading-[0.98] tracking-[-0.035em] text-slate-950">
              Find the CarePT clinic closest to your recovery.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-8 text-slate-600">
              CarePT serves communities across Louisiana and Mississippi with six clinics, clear contact points, and a
              consistent clinical standard from one location to the next.
            </p>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1.08fr_0.92fr]">
            <figure class="relative min-h-[440px] overflow-hidden rounded-[38px] bg-skybrand-900 shadow-elevated lg:min-h-[660px]">
              <Image id="clinic-image" src={hattiesburgClinic} alt="CarePT Hattiesburg clinic exterior" class="absolute inset-0 h-full w-full object-cover transition duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-transparent to-transparent"></div>
              <figcaption class="absolute bottom-8 left-8 right-8 text-white">
                <h3 id="clinic-title" class="font-display text-4xl font-bold">Hattiesburg, MS</h3>
                <p id="clinic-copy" class="mt-2 text-sm text-skybrand-100">One of six CarePT clinics serving patients across south Mississippi.</p>
              </figcaption>
            </figure>
            <div class="grid gap-3 lg:grid-rows-6">
              {clinics.map((clinic, index) => (
                <button
                  class:list={[
                    "location-item group relative flex min-h-[92px] flex-col justify-center rounded-2xl border p-5 text-left transition hover:-translate-y-0.5 hover:border-skybrand-400 hover:bg-white hover:shadow-card focus:outline-none focus:ring-2 focus:ring-skybrand-400",
                    index === 0 ? "is-active border-skybrand-800 bg-skybrand-800 text-white shadow-card" : "border-slate-200 bg-white/80 text-slate-900",
                  ]}
                  type="button"
                  data-title={clinic.title}
                  data-copy={clinic.copy}
                  data-image={clinic.image.src}
                  data-alt={clinic.alt}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span class="location-name font-bold">{clinic.title}</span>
                  <span class:list={["location-detail mt-1 text-sm", index === 0 ? "text-skybrand-100" : "text-slate-500"]}>{clinic.detail}</span>
                  <span class:list={["location-state absolute right-5 top-1/2 hidden -translate-y-1/2 text-[11px] font-black uppercase tracking-[0.08em] sm:block", index === 0 ? "text-skybrand-100" : "text-skybrand-600 opacity-0 group-hover:opacity-100"]}>
                    {index === 0 ? "Selected" : "View clinic"}
                  </span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="team" class="bg-white px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="mb-10 grid items-end gap-8 lg:grid-cols-[0.92fr_0.6fr]">
            <div>
              <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
                Meet the clinicians
              </p>
              <h2 class="font-display text-[clamp(38px,5vw,68px)] font-bold leading-[0.98] tracking-[-0.035em] text-slate-950">
                Expertise with the warmth that makes recovery feel human.
              </h2>
            </div>
            <p class="text-[17px] leading-8 text-slate-600">
              CarePT's clinicians bring licensed expertise and local trust to the treatment room, translating clinical
              plans into progress patients can feel.
            </p>
          </div>
          <div class="grid auto-cols-[minmax(178px,1fr)] grid-flow-col gap-4 overflow-x-auto pb-3">
            {team.map((member) => (
              <article class="min-w-[178px] overflow-hidden rounded-3xl border border-slate-200 bg-slate-50">
                <Image src={member.image} alt={member.name} class="aspect-[0.82] w-full object-cover object-top" />
                <div class="p-4">
                  <h3 class="text-sm font-extrabold text-slate-950">{member.name}</h3>
                  <p class="mt-1 text-xs text-slate-500">{member.role}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="appointment" class="bg-slate-950 px-6 py-24 text-white lg:px-10 xl:px-16">
        <div class="mx-auto grid max-w-[1280px] items-center gap-12 lg:grid-cols-[0.76fr_0.88fr]">
          <div>
            <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-white before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-400">
              Request an appointment
            </p>
            <h2 class="font-display text-[clamp(38px,5vw,68px)] font-bold leading-[0.98] tracking-[-0.035em]">
              Start with a team that sees the whole picture.
            </h2>
            <p class="mt-5 max-w-xl text-[17px] leading-8 text-slate-300">
              Tell us where you are, what hurts, and which clinic fits your week. CarePT will help you take the next step
              toward pain relief, better movement, and more confidence.
            </p>
            <div class="mt-8 grid gap-3 sm:grid-cols-2">
              <div class="rounded-r-2xl border-l-2 border-skybrand-400 bg-white/5 p-5 text-sm leading-6 text-slate-300">
                <strong class="mb-1 block text-white">Whole-body treatment</strong>
                Care that connects your symptoms, goals, habits, and daily demands.
              </div>
              <div class="rounded-r-2xl border-l-2 border-skybrand-400 bg-white/5 p-5 text-sm leading-6 text-slate-300">
                <strong class="mb-1 block text-white">Trusted regional access</strong>
                Six clinics across Louisiana and Mississippi with one clinical standard.
              </div>
            </div>
          </div>
          <form class="rounded-[34px] bg-white p-8 text-slate-950 shadow-elevated" name="appointment" method="POST" data-netlify="true" netlify-honeypot="bot-field" aria-label="Appointment request">
            <input type="hidden" name="form-name" value="appointment" />
            <input type="hidden" name="bot-field" />
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="grid gap-2 text-xs font-black text-slate-800">First name<input class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="first-name" autocomplete="given-name" required /></label>
              <label class="grid gap-2 text-xs font-black text-slate-800">Last name<input class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="last-name" autocomplete="family-name" required /></label>
              <label class="grid gap-2 text-xs font-black text-slate-800">Email<input class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="email" type="email" autocomplete="email" required /></label>
              <label class="grid gap-2 text-xs font-black text-slate-800">Phone<input class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="phone" type="tel" autocomplete="tel" required /></label>
              <label class="grid gap-2 text-xs font-black text-slate-800">Preferred clinic<select class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="preferred-clinic"><option>Covington, LA</option><option>Bogalusa, LA</option><option>Franklinton, LA</option><option>Ponchatoula, LA</option><option>Hattiesburg, MS</option><option>Sumrall, MS</option></select></label>
              <label class="grid gap-2 text-xs font-black text-slate-800">New patient?<select class="min-h-11 rounded-xl border border-slate-200 bg-slate-50 px-3 outline-none transition focus:border-skybrand-500" name="patient-status"><option>Yes</option><option>No</option><option>Not sure</option></select></label>
              <label class="grid gap-2 text-xs font-black text-slate-800 sm:col-span-2">What do you need help with?<textarea class="min-h-28 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-3 outline-none transition focus:border-skybrand-500" name="message"></textarea></label>
            </div>
            <button class="mt-5 inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-full bg-skybrand-800 px-6 text-sm font-extrabold text-white transition hover:bg-skybrand-900" type="submit">
              Send appointment request
              <ArrowRight class="h-4 w-4" />
            </button>
          </form>
        </div>
      </section>
    </main>

    <footer class="bg-slate-900 px-6 py-14 text-white lg:px-10 xl:px-16">
      <div class="mx-auto grid max-w-[1280px] gap-10 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <Image src={logoWhite} alt="Care Physical Therapy" class="h-auto w-40" />
          <p class="mt-5 max-w-sm text-sm leading-7 text-slate-300">
            Individualized, hands-on physical therapy for pain, mobility, strength, balance, and confidence.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {clinics.map((clinic) => (
            <div class="rounded-3xl bg-white/5 p-5 ring-1 ring-white/10">
              <h3 class="font-bold text-white">{clinic.title}</h3>
              <p class="mt-2 text-sm text-slate-300">{clinic.address}</p>
              <a href={`tel:${clinic.phone.replace(/\D/g, "")}`} class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-skybrand-200">
                <Phone class="h-4 w-4" />
                {clinic.phone}
              </a>
            </div>
          ))}
        </div>
      </div>
      <div class="mx-auto mt-10 flex max-w-[1280px] flex-col gap-2 border-t border-white/10 pt-6 text-sm text-slate-400 sm:flex-row sm:justify-between">
        <span>© 2026 Care Physical Therapy. All rights reserved.</span>
        <span>Louisiana & Mississippi</span>
      </div>
    </footer>
  </div>

  <script is:inline>
    (() => {
      const river = document.querySelector("#locations");
      if (!river) return;

      const feature = river.querySelector("#clinic-image");
      const title = river.querySelector("#clinic-title");
      const copy = river.querySelector("#clinic-copy");
      const buttons = Array.from(river.querySelectorAll(".location-item"));
      let active = feature?.getAttribute("src");

      const activeClasses = ["is-active", "border-skybrand-800", "bg-skybrand-800", "text-white", "shadow-card"];
      const inactiveClasses = ["border-slate-200", "bg-white/80", "text-slate-900"];

      function setButtonState(button, selected) {
        button.classList.toggle("is-active", selected);
        button.setAttribute("aria-pressed", String(selected));
        activeClasses.slice(1).forEach((className) => button.classList.toggle(className, selected));
        inactiveClasses.forEach((className) => button.classList.toggle(className, !selected));

        const detail = button.querySelector(".location-detail");
        const state = button.querySelector(".location-state");
        detail?.classList.toggle("text-skybrand-100", selected);
        detail?.classList.toggle("text-slate-500", !selected);
        state?.classList.toggle("text-skybrand-100", selected);
        state?.classList.toggle("text-skybrand-600", !selected);
        state?.classList.toggle("opacity-0", !selected);
        if (state) state.textContent = selected ? "Selected" : "View clinic";
      }

      function showClinic(button) {
        const next = button.dataset.image;
        buttons.forEach((candidate) => setButtonState(candidate, candidate === button));
        if (!next || next === active || !feature || !title || !copy) return;
        active = next;
        feature.setAttribute("src", next);
        feature.setAttribute("alt", button.dataset.alt || "");
        title.textContent = button.dataset.title || "";
        copy.textContent = button.dataset.copy || "";
      }

      buttons.forEach((button) => {
        button.addEventListener("mouseenter", () => showClinic(button));
        button.addEventListener("focus", () => showClinic(button));
        button.addEventListener("click", () => showClinic(button));
      });
    })();
  </script>
</BaseLayout>

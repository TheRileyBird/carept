    title: "Franklinton, LA",
    detail: "44626 J Meadie Knight Dr. · (985) 795-1746",
    copy: "44626 J Meadie Knight Drive · (985) 795-1746",
    image: franklintonClinic,
    alt: "CarePT Franklinton clinic",
    phone: "(985) 795-1746",
    address: "44626 J Meadie Knight Drive",
  },
  {
    title: "Ponchatoula, LA",
    detail: "1625 Hwy 51 Suite C · (985) 386-2222",
    copy: "1625 Hwy 51 Suite C · (985) 386-2222",
    image: ponchatoulaClinic,
    alt: "CarePT Ponchatoula clinic",
    phone: "(985) 386-2222",
    address: "1625 Hwy 51 Suite C",
  },
  {
    title: "Sumrall, MS",
    detail: "4877 Mississippi 589 · (601) 758-3333",
    copy: "4877 Mississippi 589 · (601) 758-3333",
    image: sumrallClinic,
    alt: "CarePT rehab session",
    phone: "(601) 758-3333",
    address: "4877 Mississippi 589",
  },
];

const team = [
  { name: "Byron Blackwell", role: "MPT — Bogalusa", image: byronBlackwellImage },
  { name: "Brian Cochran", role: "PT, MCMT — Covington", image: brianCochranImage },
  { name: "C. Ryan Tate", role: "DPT — Covington", image: ryanTateImage },
  { name: "Heath Villere", role: "DPT — Covington", image: heathVillereImage },
  { name: "Kelvin McCain", role: "PT — Franklinton", image: kelvinMccainImage },
  { name: "Jonathan Mitchell", role: "PT, ATC — Ponchatoula", image: jonathanMitchellImage },
  { name: "Billy Cochran", role: "PT, CSCS — Hattiesburg", image: billyCochranImage },
  { name: "Stephanie Elkins", role: "DPT — Sumrall", image: stephanieElkinsImage },
];

---

<BaseLayout
  title="CarePT Physical Therapy"
  description="CarePT helps patients move through pain, surgery, injury, and uncertainty with hands-on treatment, clear plans, and attentive care."
>
  <div class="index-page overflow-hidden bg-white pt-[78px] text-slate-900">
    <SiteHeader />

    <main>
      <section class="grid min-h-[calc(100svh-78px)] overflow-hidden bg-gradient-to-b from-skybrand-200 via-skybrand-50 to-white lg:grid-cols-2">
        <div class="flex flex-col justify-center px-6 py-20 sm:px-10 lg:px-[calc((100vw-min(1280px,100vw-48px))/2+24px)] lg:pr-16">
          <div class="mb-8 inline-flex w-fit items-center gap-3 rounded-full border border-slate-700/30 bg-white/70 px-4 py-2">
            <ShieldCheck class="h-4 w-4" />
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-slate-700">Doctor-trusted · Insurance accepted</span>
          </div>
          <h1 class="max-w-2xl font-display text-[clamp(46px,5vw,125px)] font-black leading-[0.94] tracking-[-0.038em] text-sky-700">
            Heal<span class="text-skybrand-600">.</span><br>
            <span class="text-skybrand-800">Strengthen</span><span class="text-skybrand-600">.</span><br>
            <span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">Thrive</span><span class="text-skybrand-600">.</span>
          </h1>
          <p class="mt-7 max-w-xl text-[17px] text-slate-700">
            Individualized, hands-on care at 6 convenient locations across Louisiana and Mississippi. When you're here, you're family.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#appointment" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-skybrand-800 px-6 text-sm font-extrabold text-white shadow-card transition hover:-translate-y-0.5 hover:bg-skybrand-900">
              <CalendarDays class="h-4 w-4" />
              Request an appointment
            </a>
            <a href="#locations" class="inline-flex min-h-11 items-center justify-center rounded-full border border-skybrand-800/20 bg-white/70 px-6 text-sm font-extrabold text-skybrand-900 transition hover:-translate-y-0.5 hover:border-skybrand-800/40 hover:bg-white">
              Find a clinic
            </a>
          </div>
        </div>

        <div class="relative min-h-[520px] overflow-hidden rounded-bl-[72px] bg-slate-900 lg:min-h-[calc(100svh-78px)] lg:rounded-bl-[120px]">
          <Image src={teamHeroImage} alt="CarePT team members" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/10 to-transparent"></div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-slate-950" aria-label="Accepted insurance carriers">
        <span class="absolute left-6 top-1/2 z-10 flex -translate-y-1/2 items-center gap-2 rounded-full border border-skybrand-500/40 bg-slate-950 px-4 py-2 text-[11px] font-black uppercase tracking-[0.12em] text-skybrand-100 shadow-[16px_0_24px_rgb(2_6_23)] sm:left-10">
          <span class="h-2 w-2 rounded-full bg-skybrand-400"></span>
          Insurance accepted
        </span>
        <div class="flex min-h-[58px] items-center overflow-hidden pl-48">
          <div class="flex w-max animate-marquee items-center motion-reduce:animate-none">
            {[...insuranceCarriers, ...insuranceCarriers].map((carrier) => (
              <>
                <span class="whitespace-nowrap px-7 text-[13px] font-bold text-white/70">{carrier}</span>
                <span class="h-1 w-1 shrink-0 rounded-full bg-skybrand-400/70"></span>
              </>
            ))}
          </div>
        </div>
      </section>

      <section id="conditions" class="border-b border-slate-200 bg-white px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto grid max-w-[1280px] items-center gap-16 lg:grid-cols-[0.82fr_1fr]">
          <div class="relative min-h-[420px] lg:min-h-[540px]">
            <figure class="absolute inset-y-0 left-0 right-16 overflow-hidden rounded-[110px_28px_28px_28px] bg-slate-100 shadow-elevated">
              <Image src={manualTherapyImage} alt="Therapist guiding a patient through hands-on care" class="h-full w-full object-cover" />
            </figure>
            <figure class="absolute bottom-0 right-0 w-[52%] overflow-hidden rounded-[28px_28px_90px_28px] border-[10px] border-white bg-slate-100 shadow-elevated">
              <Image src={treatmentRoomImage} alt="CarePT treatment room" class="aspect-[0.84] h-full w-full object-cover" />
            </figure>
          </div>
          <div>
            <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
              First-time patients
            </p>
            <h2 class="max-w-xl font-display text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em] text-slate-950">
              More Than a Clinic.<br>
              We're <span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">Your Team</span>.
            </h2>
            <p class="mt-5 max-w-xl text-[17px] text-slate-600">
              At Care Physical Therapy, pain is never just physical. It touches how you sleep, how you move, and how you show up for the people who matter most.
            </p>
            <p class="mt-5 max-w-xl text-[17px] text-slate-600">
              That's why we do not just treat the injury. We evaluate your whole body, understand your whole life, and build a recovery plan around your specific goals.
            </p>
            <div class="mt-8 grid gap-3 sm:grid-cols-2" aria-label="Common conditions we treat">
              {conditions.map((condition) => (
                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-bold leading-tight text-slate-800">
                  <span class="h-2 w-2 shrink-0 rounded-full bg-skybrand-500"></span>
                  {condition}
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="relative overflow-hidden bg-slate-50 px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="relative mx-auto mb-14 max-w-3xl text-center">
            <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-600">What We Treat</p>
            <h2 class="font-display text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
              Whatever Is Hold You Back<br><span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">We Can Help</span>.
            </h2>
            <p class="mx-auto mt-5 max-w-xl text-base text-slate-600">Our licensed therapists have successfully treated thousands of patients across these conditions and many more.</p>
          </div>
          <div class="relative grid gap-px overflow-hidden rounded-[28px] border border-slate-200/80 bg-slate-200/80 shadow-[0_24px_70px_-46px_rgba(15,23,42,0.45)] sm:grid-cols-2 lg:grid-cols-4">
            {conditions2.map((condition) => (
                <article class="group relative min-h-[220px] overflow-hidden bg-white p-6 text-left transition duration-300 ease-out">
                  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-skybrand-800 via-skybrand-500 to-[#80be41] opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
                  <div class="relative mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-skybrand-50 to-white text-skybrand-700 ring-1 ring-skybrand-100 transition-colors duration-300 group-hover:text-skybrand-900 group-hover:ring-skybrand-300">
                    {(() => {
                      const Icon = condition.icon;
                      return <Icon class="h-5 w-5" stroke-width={2.2} />;
                    })()}
                  </div>
                  <h3 class="relative text-base font-extrabold text-slate-950">{condition.name}</h3>
                  <p class="relative mt-3 text-sm text-slate-500">{condition.copy}</p>
                </article>
            ))}
          </div>
        </div>
      </section>

      <!--<section class="px-6 py-24 lg:px-10 xl:px-16">-->
      <!--  <div class="mx-auto max-w-[1280px]">-->
      <!--  <div class="mx-auto mb-16 max-w-3xl text-center">-->
      <!--    <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-600">Your Recovery Journey</p>-->
      <!--    <h2 class="font-display text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em]">Feel Like <span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">Yourself</span> Again</h2>-->
      <!--  </div>-->
      <!--  <div class="recovery-steps relative grid gap-8 lg:grid-cols-4">-->
      <!--    <div class="recovery-line" aria-hidden="true"></div>-->
      <!--    {steps.map(([number, title, copy], index) => (-->
      <!--        <article class="relative z-10 rounded-3xl bg-white p-6 text-center shadow-[0_18px_50px_-40px_rgba(15,23,42,0.55)] ring-1 ring-slate-200/80">-->
      <!--          <div class:list={["relative z-20 mx-auto mb-6 grid h-16 w-16 place-items-center rounded-full border-[6px] border-white text-xl font-black text-white shadow-[0_12px_28px_-14px_rgba(15,79,138,0.8)]", index % 2 ? "bg-skybrand-500" : "bg-skybrand-800"]}>-->
      <!--            {number}-->
      <!--          </div>-->
      <!--          <h3 class="text-base font-extrabold text-slate-950">{title}</h3>-->
      <!--          <p class="mt-3 text-[13px] leading-6 text-slate-600">{copy}</p>-->
      <!--        </article>-->
      <!--    ))}-->
      <!--  </div>-->
      <!--  </div>-->
      <!--</section>-->

      <section id="stories" class="bg-slate-950 px-6 py-24 text-white lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="mx-auto mb-14 max-w-3xl text-center">
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.12em] text-white/50">Patient Stories</p>
            <h2 class="font-display text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em]">Real People. <span class="text-[#d49a16]">Real Recoveries.</span></h2>
            <p class="mx-auto mt-5 max-w-xl text-base text-white/60">Hear from patients whose lives changed when they walked through our doors.</p>
          </div>
          <div class="grid gap-6 lg:grid-cols-3">
            {reviews.map(([initial, name, detail, quote]) => (
                <article class="rounded-2xl border border-white/10 bg-white/5 p-7 transition hover:bg-white/10">
                  <div class="mb-4 tracking-[0.16em] text-[#d49a16]">★★★★★</div>
                  <p class="text-[15px] leading-7 text-white/85">"{quote}"</p>
                  <div class="mt-6 flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-skybrand-500 to-skybrand-800 font-display font-bold">{initial}</div>
                    <div>
                      <p class="text-sm font-semibold text-white">{name}</p>
                      <p class="text-xs text-white/45">{detail}</p>
                    </div>
                  </div>
                </article>
            ))}
          </div>
          <div class="mt-12 grid overflow-hidden rounded-2xl bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
            {[
              ["5★", "Average Google Rating"],
              ["6+", "Clinic Locations"],
              ["1K+", "Patients Treated"],
              ["20+", "Years Serving Communities"],
            ].map(([number, label]) => (
                <div class="border-white/10 bg-white/5 p-8 text-center lg:border-l first:border-l-0">
                  <p class="font-display text-4xl font-black text-white">{number}</p>
                  <p class="mt-2 text-sm leading-5 text-white/50">{label}</p>
                </div>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-white px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto grid max-w-[1280px] items-center gap-16 lg:grid-cols-[0.88fr_1fr]">
          <div>
            <p class="mb-5 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700 before:block before:h-0.5 before:w-7 before:rounded-full before:bg-skybrand-600">
              Referral-friendly care
            </p>
            <h2 class="text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em] text-slate-950">
              <span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">Trusted</span> by physicians.
            </h2>
            <p class="mt-5 max-w-xl text-[17px] text-slate-600">
              A strong referral experience depends on clarity: the patient understands the plan, the therapist tracks
              what is changing, and the physician can trust that care is progressing with purpose.
            </p>
            <div class="mt-9 divide-y divide-skybrand-100 border-y border-skybrand-100">
              {[
                ["Evaluate", "The whole picture", "Pain, movement, work demands, sleep, surgery history, and patient goals."],
                ["Treat", "With intention", "Hands-on care, targeted exercise, and education patients can actually use."],
                ["Restore", "Daily confidence", "Less pain, steadier movement, and a body patients trust again."],
              ].map(([label, title, copy]) => (
                <article class="py-5">
                  <div>
                    <span class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.08em] text-skybrand-600">
                      <span class="h-1.5 w-1.5 rounded-full bg-skybrand-500 shadow-[0_0_0_3px_rgba(224,242,254,1)]"></span>
                      {label}
                    </span>
                    <strong class="mt-1 block text-2xl font-extrabold leading-tight text-slate-950">{title}</strong>
                    <p class="mt-2 text-sm leading-6 text-slate-600">{copy}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
          <aside class="relative flex min-h-[520px] flex-col justify-end overflow-hidden rounded-[48px_48px_48px_48px] p-8 text-white shadow-elevated sm:p-12">
            <Image src={quoteImg} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" />
            <div class="absolute inset-0 bg-gradient-to-b from-slate-950/60 to-slate-950/95"></div>
            <div class="relative">
              <span class="inline-flex rounded-full bg-white/15 px-3 py-2 text-[11px] font-black uppercase tracking-[0.1em] text-skybrand-100 backdrop-blur">Patient outcome</span>
              <Quote class="mt-8 h-10 w-10 text-white/30" />
              <blockquote class="mt-4 max-w-xl font-display text-[clamp(30px,4vw,56px)] font-bold leading-none tracking-[-0.03em]">
                I won't be having surgery and I give the credit to my friends at CARE Physical Therapy.
              </blockquote>
            </div>
          </aside>
        </div>
      </section>

      <section id="locations" class="bg-slate-50 px-6 py-24 lg:px-10 xl:px-16">
        <div class="mx-auto max-w-[1280px]">
          <div class="mx-auto mb-14 max-w-4xl text-center">
            <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.12em] text-skybrand-700">Six convenient locations</p>
            <h2 class="font-display text-[clamp(36px,4vw,48px)] font-extrabold leading-[0.98] tracking-[-0.035em] text-slate-950">
              Ready to <span class="animate-animated-text bg-[linear-gradient(-45deg,#3da8cf,#1B4F8A,#3da8cf)] bg-[length:300%] bg-clip-text text-transparent">feel better</span>? We're nearby.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-[17px] text-slate-600">
              CarePT serves communities across Louisiana and Mississippi with six clinics, clear contact points, and a
              consistent clinical standard from one location to the next.
            </p>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1.08fr_0.92fr]">
            <figure class="relative min-h-[440px] overflow-hidden rounded-[38px] bg-skybrand-900 shadow-elevated lg:min-h-[660px]">
              <Image id="clinic-image" src={hattiesburgClinic} alt="CarePT Hattiesburg clinic exterior" class="absolute inset-0 h-full w-full object-cover transition duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-transparent to-transparent"></div>
              <figcaption class="absolute bottom-8 left-8 right-8 text-white">
                <h3 id="clinic-title" class="font-display text-4xl font-bold">Hattiesburg, MS</h3>
                <p id="clinic-copy" class="mt-2 text-sm text-skybrand-100">One of six CarePT clinics serving patients across south Mississippi.</p>
              </figcaption>
            </figure>
            <div class="grid gap-3 lg:grid-rows-6">
              {clinics.map((clinic, index) => (
                <button
                  class:list={[

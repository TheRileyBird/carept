---
import { Image } from "astro:assets";
import logo from "../assets/brand/logo.svg";

const navItems = [
  { label: "Services", href: "#services" },
  { label: "Conditions", href: "#conditions" },
  { label: "Locations", href: "#locations" },
  { label: "Team", href: "#team" },
  { label: "Appointment", href: "#appointment" },
];
---

<header
  data-site-header
  class="fixed inset-x-0 top-0 z-50 border-b border-slate-200/70 bg-white/90 shadow-none backdrop-blur-xl transition-all duration-200"
>
  <div
    data-site-header-inner
    class="mx-auto flex h-[78px] w-full max-w-[1280px] items-center justify-between gap-6 px-6 transition-all duration-200 lg:grid lg:grid-cols-[1fr_auto_1fr] lg:px-10"
  >
    <a href="/" aria-label="CarePT home" class="justify-self-start">
      <Image
        data-site-header-logo
        src={logo}
        alt="Care Physical Therapy"
        class="h-auto w-[152px] transition-all duration-200"
      />
    </a>

    <nav class="hidden items-center justify-center gap-8 justify-self-center text-[13.5px] font-bold text-slate-500 lg:flex" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} class="transition hover:text-skybrand-800">{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center justify-end gap-3 justify-self-end">
      <a
        data-site-header-button
        href="tel:+19852496111"
        class="hidden min-h-11 items-center justify-center rounded-full border border-slate-200 bg-white px-5 text-[13.5px] font-extrabold text-slate-800 transition-all duration-200 hover:-translate-y-0.5 hover:border-skybrand-300 hover:shadow-card sm:inline-flex"
      >
        Call CarePT
      </a>
      <a
        data-site-header-button
        href="#appointment"
        class="inline-flex min-h-11 items-center justify-center rounded-full border border-skybrand-800 bg-skybrand-800 px-5 text-[13.5px] font-extrabold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-skybrand-900 hover:shadow-card"
      >
        Request a visit
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-site-header]");
    const inner = document.querySelector("[data-site-header-inner]");
    const logo = document.querySelector("[data-site-header-logo]");
    const buttons = Array.from(document.querySelectorAll("[data-site-header-button]"));
    if (!header || !inner || !logo) return;

    let ticking = false;

    function updateHeader() {
      const scrolled = window.scrollY > 8;
      header.classList.toggle("shadow-[0_12px_34px_rgba(15,48,96,0.09)]", scrolled);
      inner.classList.toggle("h-[62px]", scrolled);
      inner.classList.toggle("h-[78px]", !scrolled);
      logo.classList.toggle("w-[126px]", scrolled);
      logo.classList.toggle("w-[152px]", !scrolled);
      buttons.forEach((button) => {
        button.classList.toggle("min-h-[38px]", scrolled);
        button.classList.toggle("min-h-11", !scrolled);
        button.classList.toggle("px-[18px]", scrolled);
        button.classList.toggle("px-5", !scrolled);
      });
      ticking = false;
    }

    updateHeader();
    window.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeader);
    }, { passive: true });
  })();
</script>

---
import logo from "../assets/brand/logo.svg";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CarePT | Hands-On Physical Therapy",
  description = "Individualized, hands-on physical therapy close to home across Louisiana and Mississippi.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth bg-slate-50 text-slate-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={logo.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased selection:bg-skybrand-200 selection:text-slate-900">
    <div class="relative isolate overflow-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[44rem] bg-grid-fade bg-grid"></div>
      <div class="pointer-events-none absolute right-0 top-16 -z-10 h-80 w-80 rounded-full bg-skybrand-200/40 blur-3xl"></div>
      <div class="pointer-events-none absolute left-0 top-[32rem] -z-10 h-72 w-72 rounded-full bg-goldbrand-100/60 blur-3xl"></div>
      <slot />
    </div>
  </body>
</html>
